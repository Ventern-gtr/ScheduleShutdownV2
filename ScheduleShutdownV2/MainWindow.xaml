<Window x:Class="ScheduleShutdownV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScheduleShutdownV2"
        Title="Shutdown Scheduler"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid>
        <Grid Margin="20">
            <Border Background="#2D2D30"
                CornerRadius="12"
                Padding="20">
                <StackPanel>

                    <TextBlock Text="Shutdown Scheduler"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20"/>

                    <TextBlock Text="Delay (Minutes)"
                        Foreground="White"
                        FontSize="14"
                        Margin="0,0,0,10"/>

                    <Slider x:Name="DelaySlider"
                        Minimum="1"
                        Maximum="300"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="30"
                        Margin="0,0,0,15"
                        ValueChanged="DelaySlider_ValueChanged"/>

                    <Border Background="#3C3C3C"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,20">

                        <TextBlock x:Name="DelayDisplay"
                               Text="{Binding ElementName=DelaySlider, Path=Value, StringFormat='{}{0:F0} Minutes'}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    </Border>

                    <Button x:Name="ScheduleShutdownButton"
                        Content="Schedule Shutdown"
                        Click="ScheduleShutdownButton_Click"
                        Width="400"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Background="#0078D7"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0,0,0,10"/>

                    <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Width="400"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Background="#E81123"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>